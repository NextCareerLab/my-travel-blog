---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & { headings: { depth: number; slug: string; text: string }[] };

const { title, description, pubDate, updatedDate, heroImage, headings } = Astro.props;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((post) => post.data.title !== title)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 1200px;
				margin: auto;
				padding: 3em 1em;
			}
			.blog-container {
				display: flex;
				flex-direction: row-reverse;
				gap: 3rem;
				align-items: flex-start;
			}
			.content-wrapper {
				flex: 1;
				min-width: 0; /* 👈 중요: 이미지가 레이아웃을 뚫고 나가는걸 방지합니다 */
				max-width: 720px;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
				border-radius: 12px;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				object-fit: cover;
				box-shadow: var(--box-shadow);
			}
			.prose {
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 2rem;
				padding: 1rem 0;
				text-align: center;
			}
			.date {
				margin-bottom: 0.5rem;
				color: rgb(var(--gray));
			}
			/* 목차 스타일 최적화 */
			.toc-aside {
				position: sticky;
				top: 6rem;
				width: 260px;
				display: none;
				flex-shrink: 0;
			}
			@media (min-width: 1150px) {
				.toc-aside { display: block; }
			}
			.toc-title {
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				color: var(--gray);
				margin-bottom: 1rem;
			}
			.toc-list {
				list-style: none;
				padding: 0;
				border-left: 1px solid #eee;
			}
			.toc-item a {
				display: block;
				padding: 0.4rem 0 0.4rem 1rem;
				font-size: 0.85rem;
				color: var(--gray);
				text-decoration: none;
				line-height: 1.4;
			}
			.toc-item a:hover {
				color: var(--accent);
				border-left: 2px solid var(--accent);
				margin-left: -1px;
			}

			/* 뉴스레터 & 카드 스타일 */
			.newsletter-box {
				background-color: #f8fafc;
				border-radius: 20px;
				padding: 4rem 2rem;
				margin: 3rem 0 5rem 0;
				text-align: center;
				border: 1px solid #edf2f7;
			}
			.newsletter-content h3 {
				font-family: 'Playfair Display', serif;
				font-size: 2.2rem;
				margin-bottom: 1.2rem;
				color: #1a202c;
			}
			.newsletter-content p {
				color: #4a5568;
				margin-bottom: 2.5rem;
				line-height: 1.8;
			}
			.newsletter-form {
				display: flex;
				gap: 0.8rem;
				max-width: 500px;
				margin: 0 auto;
				justify-content: center;
			}
			.newsletter-form input {
				flex: 1;
				padding: 1rem 1.2rem;
				border: 1px solid #e2e8f0;
				border-radius: 12px;
				font-size: 1rem;
			}
			.newsletter-form button {
				background-color: #333;
				color: white;
				border: none;
				padding: 1rem 2rem;
				border-radius: 12px;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.3s ease;
			}
			.newsletter-form button:hover {
				background-color: var(--accent);
				transform: translateY(-2px);
			}
			.author-card {
				background-color: var(--accent-bg);
				border-radius: 12px;
				padding: 2rem;
				margin: 0 0 4rem 0;
				border: 1px solid #eee;
			}
			.author-card h3 {
				margin-top: 0;
				font-family: 'Playfair Display', serif;
			}
			.related-section {
				margin-top: 4rem;
				padding-top: 2rem;
				border-top: 1px solid #eee;
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.5rem;
				margin-top: 1.5rem;
			}
			.related-card-link {
				text-decoration: none;
				color: inherit;
			}
			.related-card {
				background: var(--accent-bg);
				padding: 1.5rem;
				border-radius: 12px;
				border: 1px solid transparent;
				transition: all 0.3s ease;
				height: 100%;
			}
			.related-card:hover {
				border-color: var(--accent);
				transform: translateY(-5px);
			}
			.related-card h4 {
				margin: 0 0 0.5rem 0;
				font-family: 'Playfair Display', serif;
			}
			.read-more-text {
				font-size: 0.8rem;
				font-weight: bold;
				color: var(--accent);
			}
			.newsletter-footer {
				font-size: 0.85rem;
				margin-top: 1.5rem !important;
				color: #a0aec0;
			}
			@media (max-width: 600px) {
				.newsletter-form { flex-direction: column; }
				.newsletter-form button { width: 100%; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="blog-container">
				<aside class="toc-aside">
					<nav>
						<p class="toc-title">On this page</p>
						<ul class="toc-list">
							{headings.filter(h => h.depth <= 3).map(h => (
								<li class={`toc-item depth-${h.depth}`}>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>

				<div class="content-wrapper">
					<article>
						<div class="hero-image">
							{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
						</div>
						
						<div class="prose">
							<div class="title">
								<div class="date"><FormattedDate date={pubDate} /></div>
								<h1>{title}</h1>
								<hr />
							</div>
							
							<slot />
							
							<hr />
							
							<section class="newsletter-box">
								<div class="newsletter-content">
									<h3>Join the Calm Day Journey</h3>
									<p>
										Get insights on <strong>data-driven mindfulness</strong> and inner peace delivered straight to your inbox. <br/> 
										Be the first to hear about new stories and the upcoming <strong>'Calm Day'</strong> project.
									</p>
									<form class="newsletter-form">
										<input type="email" placeholder="Your email address" required />
										<button type="submit">Join the Journey</button>
									</form>
									<p class="newsletter-footer">No spam, just mindful stories from Jeju.</p>
								</div>
							</section>

							<div class="author-card">
								<div class="author-info">
									<h3>About the Author: Laf</h3>
									<p>
										A data-driven planner based in Jeju Island. 
										I help people reconnect with their true selves using EEG data and mindfulness. 
										Currently developing <strong>'Calm Day'</strong> to make self-love a daily habit.
									</p>
									<div class="author-links" style="margin-top: 1rem;">
										<a href="/about" style="color: var(--accent); font-weight: bold; text-decoration: none;">Read My Story →</a>
									</div>
								</div>
							</div>

							<section class="related-section">
								<h3 class="related-title">More from Laf's Journal</h3>
								<div class="related-grid">
									{relatedPosts.map((post) => (
										<a href={`/blog/${post.id}/`} class="related-card-link">
											<div class="related-card">
												<h4>{post.data.title}</h4>
												<p>{post.data.description ? post.data.description.substring(0, 60) + "..." : "Read more about this story."}</p>
												<span class="read-more-text">Read Post →</span>
											</div>
										</a>
									))}
								</div>
							</section>
						</div>
					</article>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>