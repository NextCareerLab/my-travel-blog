---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main { 
				width: 960px; /* 위쪽 히어로 박스와 동일한 너비로 고정 */
				max-width: calc(100% - 2em); 
				margin: auto; 
				padding: 3em 0; 
			}
			ul { 
				display: grid; 
				grid-template-columns: repeat(2, 1fr); /* 정확히 2열 정렬 */
				gap: 3rem; /* 사진 사이의 넉넉한 간격 */
				list-style-type: none; 
				margin: 0; 
				padding: 0; 
			}
			ul li { width: 100%; }
			ul li a { display: block; text-decoration: none; }
			
			/* 사진 크기 및 비율 통일 */
			ul li img { 
				width: 100%;
				aspect-ratio: 16 / 9; /* 모든 사진 비율을 16:9로 강제 통일 */
				object-fit: cover; /* 이미지가 찌그러지지 않게 채움 */
				margin-bottom: 1.5rem; 
				border-radius: 16px; 
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			
			.title { 
				margin: 0 0 0.5rem 0; 
				color: rgb(var(--black)); 
				line-height: 1.3; 
				font-family: 'Playfair Display', serif; 
				font-size: 1.4rem; 
			}
			.date { margin: 0; color: rgb(var(--gray)); font-size: 0.9rem; }
			
			/* 호버 효과 */
			ul li a:hover .title { color: var(--accent); }
			ul li a:hover img { 
				transform: translateY(-8px);
				box-shadow: 0 12px 24px rgba(0,0,0,0.1); 
			}

			@media (max-width: 720px) {
				ul { grid-template-columns: 1fr; gap: 2.5rem; }
				.title { font-size: 1.25rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img src={post.data.heroImage} alt={post.data.title} />
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>