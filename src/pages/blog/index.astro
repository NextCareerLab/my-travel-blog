---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts'; 
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

// 모든 블로그 글을 가져와서 최신순으로 정렬합니다. (슬라이스 제거하여 전체 목록 노출)
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 0;
			}
			.latest-journals-section h2 {
				font-family: 'Playfair Display', serif;
				margin-bottom: 2.5rem;
				font-size: 1.8rem;
				text-align: center;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 3rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li { width: 100%; }
			ul li a { text-decoration: none; }
			ul li img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				margin-bottom: 1.5rem;
				border-radius: 16px;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-family: 'Playfair Display', serif;
				font-size: 1.4rem;
			}
			.date { margin: 0; color: rgb(var(--gray)); font-size: 0.9rem; }
			ul li a:hover .title { color: rgb(var(--accent)); }
			ul li a:hover img {
				transform: translateY(-8px);
				box-shadow: 0 12px 24px rgba(0,0,0,0.1);
			}
			@media (max-width: 720px) {
				ul { grid-template-columns: 1fr; gap: 2rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="latest-journals-section">
				<h2>Lab & Journal</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img src={post.data.heroImage} alt={post.data.title} />
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>