---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px; /* 👈 위쪽 박스와 가로폭을 똑같이 맞춥니다 */
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 0;
			}
			.hero-section {
				background-color: #fcfcfc;
				padding: 4rem 2rem;
				border-radius: 20px;
				margin-bottom: 5rem;
				border: 1px solid #eee;
				text-align: center;
			}
			.latest-journals-section h2 {
				font-family: 'Playfair Display', serif;
				margin-bottom: 3rem;
				font-size: 1.8rem;
				text-align: left; /* 👈 제목을 왼쪽으로 정렬해서 깔끔하게 */
			}
			
			/* 글 목록 그리드 - 시원하게 벌려줍니다 */
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 4rem; /* 👈 사진 사이 간격을 아주 넉넉하게 줬습니다 */
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li { width: 100%; }
			ul li a { text-decoration: none; display: block; }
			
			/* 사진 비율 고정 (16:9) */
			ul li img {
				width: 100%;
				aspect-ratio: 16 / 9; /* 👈 모든 사진 크기를 똑같이 강제합니다 */
				object-fit: cover;
				margin-bottom: 1.5rem;
				border-radius: 16px;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			
			.title {
				margin: 0 0 0.5rem 0;
				color: #1a202c;
				line-height: 1.3;
				font-family: 'Playfair Display', serif;
				font-size: 1.4rem;
			}
			.date { margin: 0; color: #718096; font-size: 0.9rem; }
			
			/* 마우스 올렸을 때 효과 */
			ul li a:hover .title { color: var(--accent); }
			ul li a:hover img {
				transform: translateY(-8px);
				box-shadow: 0 12px 24px rgba(0,0,0,0.1);
			}

			@media (max-width: 720px) {
				main { width: 100%; padding: 1em; }
				ul { grid-template-columns: 1fr; gap: 2.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1>I liberate others <br />through my own freedom.</h1>
				<p class="hero-subtitle">
					I am <strong>Laf</strong>, a data-driven planner based in Jeju Island. <br />
					Helping you discover your unique narrative and <br />
					become the master of your own life through <strong>data and mindfulness</strong>.
				</p>
				<div class="cta-buttons">
					<a href="/about" class="btn-primary">My Story</a>
					<a href="/blog" class="btn-secondary">Read Blog</a>
				</div>
			</section>

			<section class="latest-journals-section">
				<h2>Latest Journals</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img src={post.data.heroImage} alt={post.data.title} />
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>