---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

// ⭐️ 에러 해결의 핵심: HeaderLink를 명시적으로 불러와야 합니다! ⭐️
import HeaderLink from '../components/HeaderLink.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<header>
	<nav>
		<h2 class="logo"><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Lab & Journal</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5rem;
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between; /* 로고 왼쪽, 메뉴 오른쪽 */
		max-width: 960px;
		margin: 0 auto;
		height: 70px;
	}
	.logo {
		margin: 0;
		font-size: 1.1rem;
		white-space: nowrap;
	}
	.logo a {
		text-decoration: none;
		font-weight: 800;
		color: #1a202c;
	}
	
	/* 🟢 메뉴가 안 보인다면 이 설정이 범인일 확률이 높아요 */
	.internal-links {
		display: flex !important; /* 강제 가로 정렬 */
		gap: 0.5rem;
	}

	/* HeaderLink 내부의 a 태그 스타일링 */
	.internal-links a {
		padding: 0.5rem 0.8rem;
		color: #4a5568;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		border-bottom: 3px solid transparent;
		transition: all 0.2s;
	}
	
	.internal-links a.active {
		color: #55729e;
		border-bottom-color: #55729e;
		font-weight: 700;
	}

	.internal-links a:hover {
		color: #55729e;
	}

	/* ✅ 모바일 대응 */
	@media (max-width: 720px) {
		header { padding: 0 1rem; }
		nav { height: 60px; }
		.logo { font-size: 1rem; }
		.internal-links { gap: 0.2rem; }
		.internal-links a { font-size: 0.8rem; padding: 0.4rem 0.5rem; }
	}
</style>