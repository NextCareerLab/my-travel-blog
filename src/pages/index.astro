---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts'; 
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

// 모든 블로그 글을 가져와서 최신순으로 4개만 보여줍니다.
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px; /* 👈 위쪽 박스와 가로폭을 똑같이 맞춥니다 */
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 0;
			}
			.hero-section {
				background-color: #fcfcfc;
				padding: 4rem 2rem;
				border-radius: 20px;
				margin-bottom: 5rem;
				border: 1px solid #eee;
				text-align: center;
			}
			.latest-journals-section h2 {
				font-family: 'Playfair Display', serif;
				margin-bottom: 3rem;
				font-size: 1.8rem;
				text-align: left;
			}
			
			/* 글 목록 그리드 - 시원하게 벌려줍니다 */
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 4rem; /* 👈 사진 사이 간격을 아주 넉넉하게 줬습니다 */
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li { width: 100%; }
			ul li a { text-decoration: none; display: block; }
			
			/* 사진 비율 고정 (16:9) */
			ul li img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				margin-bottom: 1.5rem;
				border-radius: 16px;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			
			.title {
				margin: 0 0 0.5rem 0;
				color: #1a202c;
				line-height: 1.3;
				font-family: 'Playfair Display', serif;
				font-size: 1.4rem;
			}
			.date { margin: 0; color: #718096; font-size: 0.9rem; }
			
			/* 호버 효과 */
			ul li a:hover .title { color: var(--accent); }
			ul li a:hover img {
				transform: translateY(-8px);
				box-shadow: 0 12px 24px rgba(0,0,0,0.1);
			}

			@media (max-width: 720px) {
				main { width: 100%; padding: 1em; }
				ul { grid-template-columns: 1fr; gap: 2.5rem; }
			}

/* 버튼 스타일 다시 살리기 */
.cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
}

.btn-primary {
    background-color: #55729e; /* 예전 파란색 톤 */
    color: white !important;
    padding: 0.8rem 1.8rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s;
}

.btn-primary:hover {
    background-color: #445b7d;
}

.btn-secondary {
    background-color: white;
    color: #55729e !important;
    padding: 0.8rem 1.8rem;
    border-radius: 8px;
    font-weight: 600;
    border: 1px solid #55729e;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-secondary:hover {
    background-color: #f8f9fa;
}

/* index.astro 내 스타일 추가 */
.cta-buttons {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 2.5rem;
}

.btn-primary, .btn-secondary {
    padding: 0.8rem 1.5rem;
    border-radius: 50px; /* 좀 더 둥글고 세련된 느낌 */
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-block;
    min-width: 120px;
    text-align: center;
}

.btn-primary {
    background-color: #55729e;
    color: white !important;
}

.btn-secondary {
    background-color: white;
    color: #55729e !important;
    border: 1px solid #55729e;
}

/* 모바일에서 버튼이 너무 작아지지 않게 */
@media (max-width: 600px) {
    .cta-buttons {
        flex-direction: row; /* 한 줄 유지 */
        padding: 0 1rem;
    }
    .btn-primary, .btn-secondary {
        flex: 1; /* 똑같은 너비로 채우기 */
        font-size: 0.9rem;
        padding: 0.7rem 0.5rem;
    }
}

		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1>I liberate others <br />through my own freedom.</h1>
				<p class="hero-subtitle">
					I am <strong>Laf</strong>, a data-driven planner based in Jeju Island. <br />
					Helping you discover your unique narrative and <br />
					become the master of your own life through <strong>data and mindfulness</strong>.
				</p>
				<div class="cta-buttons">
					<a href="/about" class="btn-primary">My Story</a>
					<a href="/blog" class="btn-secondary">Read Blog</a>
				</div>
			</section>

			<section class="latest-journals-section">
				<h2>Latest Journals</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img src={post.data.heroImage} alt={post.data.title} />
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>