---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

// HeaderLink 에러 방지를 위해 import 유지
import HeaderLink from '../components/HeaderLink.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 전역 스타일 */
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 0;
			}

			/* 히어로 섹션 */
			.hero-section {
				background-color: #fcfcfc;
				padding: 5rem 2rem;
				border-radius: 24px;
				margin-bottom: 5rem;
				border: 1px solid #eee;
				text-align: center;
			}
			.hero-section h1 {
				font-family: 'Playfair Display', serif;
				font-size: 3rem;
				margin-bottom: 1.5rem;
				line-height: 1.2;
				color: #1a202c;
			}
			.hero-subtitle {
				font-size: 1.1rem;
				color: #4a5568;
				line-height: 1.8;
			}

			/* 🟢 버튼 스타일 (강력 적용) */
			.cta-buttons {
				display: flex !important;
				gap: 1rem !important;
				justify-content: center !important;
				margin: 2.5rem 0 !important;
			}
			.btn-primary {
				background-color: #55729e !important;
				color: white !important;
				padding: 0.8rem 1.8rem !important;
				border-radius: 50px !important;
				font-weight: 700 !important;
				text-decoration: none !important;
				box-shadow: 0 4px 6px rgba(0,0,0,0.1) !important;
			}
			.btn-secondary {
				background-color: white !important;
				color: #55729e !important;
				padding: 0.8rem 1.8rem !important;
				border-radius: 50px !important;
				font-weight: 700 !important;
				text-decoration: none !important;
				border: 2px solid #55729e !important;
			}

			/* 블로그 목록 스타일 */
			.latest-journals-section h2 {
				font-family: 'Playfair Display', serif;
				margin-bottom: 3rem;
				font-size: 2rem;
				text-align: left;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 4rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li a { text-decoration: none; display: block; }
			ul li img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				margin-bottom: 1.5rem;
				border-radius: 20px;
				transition: all 0.3s ease;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: #1a202c;
				line-height: 1.4;
				font-family: 'Playfair Display', serif;
				font-size: 1.5rem;
			}
			.date { color: #718096; font-size: 0.9rem; }
			
			ul li a:hover img { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

			@media (max-width: 720px) {
				main { width: 100%; padding: 1em; }
				.hero-section h1 { font-size: 2rem; }
				ul { grid-template-columns: 1fr; gap: 3rem; }
			}
		</style>
	</head>
	<body>
		<Header /> <main>
			<section class="hero-section">
				<h1>I liberate others <br />through my own freedom.</h1>
				<p class="hero-subtitle">
					I am <strong>Laf</strong>, a data-driven planner based in Jeju Island. <br />
					Helping you discover your unique narrative and <br />
					become the master of your own life through <strong>data and mindfulness</strong>.
				</p>
				<div class="cta-buttons">
					<a href="/about" class="btn-primary">My Story</a>
					<a href="/blog" class="btn-secondary">Read Blog</a>
				</div>
			</section>

			<section class="latest-journals-section">
				<h2>Latest Journals</h2>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<img src={post.data.heroImage} alt={post.data.title} />
								<h4 class="title">{post.data.title}</h4>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main> <Footer /> </body>
</html>