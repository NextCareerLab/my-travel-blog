---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

// HeaderLink 에러 방지를 위해 import 유지
import HeaderLink from '../components/HeaderLink.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 전역 스타일 */
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 0;
			}

			/* 히어로 섹션 */
			.hero-section {
				background-color: #fcfcfc;
				padding: 5rem 2rem;
				border-radius: 24px;
				margin-bottom: 5rem;
				border: 1px solid #eee;
				text-align: center;
			}
			.hero-section h1 {
				font-family: 'Playfair Display', serif;
				font-size: 3rem;
				margin-bottom: 1.5rem;
				line-height: 1.2;
				color: #1a202c;
			}
			.hero-subtitle {
				font-size: 1.1rem;
				color: #4a5568;
				line-height: 1.8;
			}

			/* 🟢 버튼 스타일 (강력 적용) */
			.cta-buttons {
				display: flex !important;
				gap: 1rem !important;
				justify-content: center !important;
				margin: 2.5rem 0 !important;
			}
			.btn-primary {
				background-color: #55729e !important;
				color: white !important;
				padding: 0.8rem 1.8rem !important;
				border-radius: 50px !important;
				font-weight: 700 !important;
				text-decoration: none !important;
				box-shadow: 0 4px 6px rgba(0,0,0,0.1) !important;
			}
			.btn-secondary {
				background-color: white !important;
				color: #55729e !important;
				padding: 0.8rem 1.8rem !important;
				border-radius: 50px !important;
				font-weight: 700 !important;
				text-decoration: none !important;
				border: 2px solid #55729e !important;
			}

			/* 블로그 목록 스타일 */
			.latest-journals-section h2 {
				font-family: 'Playfair Display', serif;
				margin-bottom: 3rem;
				font-size: 2rem;
				text-align: left;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 4rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li a { text-decoration: none; display: block; }
			ul li img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				margin-bottom: 1.5rem;
				border-radius: 20px;
				transition: all 0.3s ease;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: #1a202c;
				line-height: 1.4;
				font-family: 'Playfair Display', serif;
				font-size: 1.5rem;
			}
			.date { color: #718096; font-size: 0.9rem; }
			
			ul li a:hover img { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

			@media (max-width: 720px) {
				main { width: 100%; padding: 1em; }
				.hero-section h1 { font-size: 2rem; }
				ul { grid-template-columns: 1fr; gap: 3rem; }
			}
		</style>
	</head>
	<body>
		<Header /> <main>
			
			<section class="latest-journals-section">
				<h2>Latest Journals</h2>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<img src={post.data.heroImage} alt={post.data.title} />
								<h4 class="title">{post.data.title}</h4>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))}
				</ul>
			</section>

<section class="newsletter-card" style="margin-top: 8rem; padding: 4rem 2rem; background-color: #f8fafd; border-radius: 30px; text-align: center; max-width: 850px; margin-left: auto; margin-right: auto; border: 1px solid #eef2f7;">
    <h2 style="font-family: 'Playfair Display', serif; font-size: 2.2rem; margin-bottom: 1rem; color: #1a202c;">Join the Calm Day Journey</h2>
    <p style="color: #4a5568; line-height: 1.6; margin-bottom: 2.5rem; font-size: 1.05rem;">
        Get insights on <strong>data-driven mindfulness</strong> and inner peace delivered straight to your inbox.<br />
        Be the first to hear about new stories and the upcoming <strong>'Calm Day'</strong> project.
    </p>

    <div class="tally-embed-container" style="max-width: 550px; margin: 0 auto; overflow: hidden;">
        <iframe 
            data-tally-src="https://tally.so/embed/wbNjgZ?hideTitle=1&transparentBackground=1&dynamicHeight=1" 
            loading="lazy" 
            width="100%" 
            height="150" 
            frameborder="0" 
            marginheight="0" 
            marginwidth="0" 
            title="Join the Journey Form">
        </iframe>
    </div>

    <p style="color: #a0aec0; font-size: 0.85rem; margin-top: 1.5rem;">No spam, just mindful stories from Jeju.</p>
</section>

<script async src="https://tally.so/widgets/embed.js"></script>

<script async src="https://tally.so/widgets/embed.js"></script>

<script async src="https://tally.so/widgets/embed.js"></script>

		</main> <Footer /> </body>
</html>